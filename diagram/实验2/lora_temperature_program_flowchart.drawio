        <mxCell id="10" value="周期性执行 LoRa 任务&#xa;LoRa_Proc()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;double=1;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="320" y="950" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="11" value="接收 LoRa 数据&#xa;LORA_Rx(lora_rx, &amp;lora_size)" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="320" y="1070" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="12" value="是否接收到数据？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="390" y="1190" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="13" value="解析温度数据帧&#xa;ParseTempFrame(lora_rx, lora_size, &amp;temp_x10)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;double=1;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="300" y="1330" width="340" height="90" as="geometry" />
        </mxCell>
        <mxCell id="14" value="数据长度是否正确？&#xa;size == LORA_TEMP_FRAME_SIZE" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="370" y="1460" width="200" height="110" as="geometry" />
        </mxCell>
        <mxCell id="15" value="帧头和帧尾是否正确？&#xa;buf[0] == 0xAA&#xa;buf[5] == 0x55" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="360" y="1620" width="220" height="130" as="geometry" />
        </mxCell>
