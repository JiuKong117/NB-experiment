  <diagram name="LoRa 温度接收程序流程图">
    <mxGraphModel dx="1300" dy="2600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="3000" math="0" shadow="0">
      <root>
