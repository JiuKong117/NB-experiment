        </mxCell>
        <mxCell id="9" value="进入 LoRa 接收状态&#xa;State = STATE_LORA_RX" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="320" y="830" width="300" height="80" as="geometry" />
